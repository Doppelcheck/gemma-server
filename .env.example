# Ollama model tag - see https://ollama.com/library for the full list.
# Default: gemma4:e2b-it-q4_K_M (~7.2 GB on disk, smallest Gemma 4
# instruct-tuned quant available on Ollama as of May 2026).
#
# Smaller alternatives if disk or RAM is tight:
#   gemma3:1b-it-q4_K_M     ~815 MB  (Gemma 3, 1B params, instruct, q4)
#   gemma3:1b               ~815 MB  (Gemma 3, 1B params, base)
#
# Any tag from https://ollama.com/library works (llama3, qwen2.5, etc.).
OLLAMA_MODEL=gemma4:e2b-it-q4_K_M

# Host port to bind. Defaults to Ollama's standard 11434, which is what
# the DoppelCheck extension expects out of the box. Change only if 11434
# is already in use on your machine.
OLLAMA_HOST_PORT=11434
